NODE_ENV=test

# ── MySQL test database ───────────────────────────────────────────────────────
# Inject real values from CI secrets or your local .env.test (gitignored)
DB_HOST=your-db-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_PORT=3306

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=test_jwt_secret_do_not_use_in_production

# ── App ───────────────────────────────────────────────────────────────────────
PORT=5001

# ── Test credentials (used by test files instead of hardcoding) ───────────────
TEST_USER_PASSWORD=Test@1234_env
TEST_VALID_PASS=valid_pass_env
TEST_CORRECT_PASS=correct_pass_env
TEST_WRONG_PASS=wrong_pass_env
